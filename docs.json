{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Skygen",
  "description": "Skygen is a multi-platform AI agent automation platform. Build, connect, and run agents across real devices, Cloud PCs, and sandboxed environments.",
  "colors": {
    "primary": "#0f172a",
    "light": "#11A4FF",
    "dark": "#0f172a"
  },
  "appearance": {
    "default": "dark"
  },
  "favicon": "/favicon.svg",
  "navigation": {
