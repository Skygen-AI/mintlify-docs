      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "guides/authentication"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/devices",
              "concepts/chat-sessions",
              "concepts/agents",
              "concepts/agent-modes",
              "concepts/confirmations",
              "concepts/cloud-pc",
              "concepts/tasks",
              "concepts/billing",
              "concepts/safety",
              "concepts/notifications"
            ]
          },
          {
            "group": "MCP & Integrations",
            "pages": [
              "concepts/mcp-integrations",
              "guides/connecting-integrations",
              "guides/custom-connectors",
              "guides/triggers"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "guides/llm-routing",
              "guides/knowledge-base",
              "guides/scheduled-tasks",
              "guides/screenshots",
              "guides/audio",
              "guides/action-history",
              "guides/analytics",
              "guides/library",
              "guides/helpdesk",
              "guides/pricing",
              "errors"
            ]
          },
          {
            "group": "Tutorials",
            "pages": [
              "tutorials/slack-digest-bot",
              "tutorials/cloud-pc-python",
              "tutorials/composio-webhooks",
              "tutorials/custom-api-connector"
            ]
          },
          {
            "group": "WebApp Architecture",
            "pages": [
              "webapp/architecture",
              "webapp/state-management",
              "webapp/api-client",
              "webapp/platform-adapter",
              "webapp/pages"
            ]
          },
          {
            "group": "Deployment & Operations",
            "pages": [
              "deployment/overview",
              "deployment/environment",
              "deployment/monitoring",
              "deployment/k8s",
              "deployment/aws-inventory",
              "deployment/cost-optimization"
            ]
          },
          {
            "group": "Admin",
            "pages": [
              "admin/overview"
            ]
          },
          {
            "group": "Trust & Compliance",
            "pages": [
              "security/subprocessors",
              "security/soc2-readiness"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": {
          "source": "openapi.json",
          "directory": "api-reference"
        },
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "api-reference/introduction"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Status",
          "href": "https://status.skygen.ai",
          "icon": "signal-bars"
        },
        {
          "anchor": "Changelog",
          "href": "https://skygen.ai/changelog",
          "icon": "newspaper"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/skygen-ai",
          "icon": "github"
        }
      ]
    }
